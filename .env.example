# Database
# Local (SQLite, default for development):
DATABASE_URL=sqlite:///./primeindex.db
# Production (Supabase Postgres) — fill in at deploy time:
# DATABASE_URL=postgresql://user:pass@host:5432/primeindex

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_PLACES_API_KEY=

# Reddit (script-type app)
REDDIT_CLIENT_ID=
